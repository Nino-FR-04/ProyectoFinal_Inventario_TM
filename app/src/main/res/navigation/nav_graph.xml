<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.ucsm.proyecto_inventario.fragments.HomeFragment"
        android:label="Inicio">

        <action
            android:id="@+id/action_HomeFragment_to_productosFragment"
            app:destination="@id/productosFragment"/>
        <action
            android:id="@+id/action_HomeFragment_to_inventarioFragment"
            app:destination="@id/inventarioFragment"/>
        <action
            android:id="@+id/action_HomeFragment_to_masFragment"
            app:destination="@id/perfilFragment"/>
    </fragment>

    <fragment
        android:id="@+id/inventarioFragment"
        android:name="com.ucsm.proyecto_inventario.fragments.InventarioFragment"
        android:label="Inventario">

        <action
            android:id="@+id/action_inventarioFragment_to_homeFragment"
            app:destination="@id/homeFragment"/>

        <action
            android:id="@+id/action_inventarioFragment_to_perfilFragment"
            app:destination="@id/perfilFragment"/>

        <action
            android:id="@+id/action_inventarioFragment_to_productosFragment"
            app:destination="@id/productosFragment"/>

        <action
            android:id="@+id/action_inventarioFragment_to_detalleFragment"
            app:destination="@id/detalleFragment"/>
    </fragment>

    <fragment
        android:id="@+id/perfilFragment"
        android:name="com.ucsm.proyecto_inventario.fragments.MasFragment"
        android:label="Perfil">

        <action
            android:id="@+id/action_perfilFragment_to_homeFragment"
            app:destination="@id/homeFragment"/>

        <action
            android:id="@+id/action_perfilFragment_to_inventarioFragment"
            app:destination="@id/inventarioFragment"/>
    </fragment>

    <fragment
        android:id="@+id/productosFragment"
        android:name="com.ucsm.proyecto_inventario.fragments.ProductosFragment"
        android:label="AgregarProductos"/>

    <fragment
        android:id="@+id/detalleFragment"
        android:name="com.ucsm.proyecto_inventario.fragments.DetalleFragment"
        android:label="ProductoDetalle">

        <action
            android:id="@+id/action_detalleFragment_to_productosFragment"
            app:destination="@id/productosFragment"/>

        <action
            android:id="@+id/action_detalleFragment_to_ajustarStockFragment"
            app:destination="@id/ajustarStockFragment"/>
    </fragment>

    <fragment
        android:id="@+id/ajustarStockFragment"
        android:name="com.ucsm.proyecto_inventario.fragments.AjustarStockFragment"
        android:label="AjustarStock"/>
</navigation>